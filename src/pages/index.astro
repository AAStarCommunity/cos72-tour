---
import "../styles/global.css";
import { roles } from "../data/roles";
import { IP_META } from "../data/roles/_schema";

const title = "Cos72 Role Tour";
const desc =
  "A comic walkthrough of Cos72 (a WebAuthn + BLS + ERC-4337 AA wallet & community OS): pick a role and see what you can do, how it works, and why it matters.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={desc} />
  </head>
  <body>
    <header class="site-head">
      <div class="wrap">
        <div class="brand">Mycelium</div>
        <nav class="topnav">
          <a class="navlink navlink-active" href="/"><span class="en">Role Tour</span><span class="zh">角色漫游</span></a>
          <a class="navlink" href="/architecture"><span class="en">Architecture</span><span class="zh">架构</span></a>
          <a class="navlink" href="/feature"><span class="en">Features</span><span class="zh">特性</span></a>
          <a class="navlink cta" href="/launch"><span class="en">Cold Launch</span><span class="zh">冷启动</span></a>
          <button class="lang-btn" id="langBtn" type="button">中文</button>
        </nav>
      </div>
    </header>

    <section class="hero">
      <div class="wrap">
        <h1>
          <span class="en">Pick a role, let the little guide walk you through</span>
          <span class="zh">选个角色，让卡通向导带你走一遍</span>
        </h1>
        <p>
          <span class="en">Cos72 is an account-abstraction wallet & community OS built on <b>WebAuthn (Face ID)</b>, <b>BLS aggregate signatures</b>, and <b>ERC-4337</b>. Below, in comics: what each role can do, the tech behind it, and why it matters to you.</span>
          <span class="zh">Cos72 是一套基于 <b>WebAuthn（刷脸）</b>、<b>BLS 聚合签名</b>、<b>ERC-4337</b> 的账户抽象钱包与社区操作系统。下面用漫画讲清楚：每个角色能做什么、背后是什么技术、对你有什么价值。</span>
        </p>
      </div>
    </section>

    <nav class="wrap">
      <div class="tabs" role="tablist">
        {roles.map((r, i) => (
          <button class="tab" role="tab" data-role={r.key} aria-selected={i === 0 ? "true" : "false"}>
            <span>{IP_META[r.ip].emoji}</span>
            <span class="en">{r.nameEn}</span>
            <span class="zh">{r.nameZh}</span>
          </button>
        ))}
      </div>
    </nav>

    <main class="wrap">
      {roles.map((r, i) => (
        <section class={`role ${i === 0 ? "active" : ""}`} data-role={r.key}>
          <p class="role-tag">
            <strong>{IP_META[r.ip].emoji} {IP_META[r.ip].name}</strong>
            <span class="en"> guides «{r.nameEn}»: {r.taglineEn}</span>
            <span class="zh"> 带你看「{r.nameZh}」：{r.taglineZh}</span>
          </p>

          <div class="steps">
            {r.steps.map((s, idx) => (
              <article class="step">
                <div class="panel">
                  <span class="stepno">{idx + 1}</span>
                  <img src={s.img} alt={s.titleEn} loading="lazy" width="1200" height="675" />
                </div>
                <div class="body">
                  <h3><span class="en">{s.titleEn}</span><span class="zh">{s.titleZh}</span></h3>
                  <p class="narr"><span class="en">{s.narrationEn}</span><span class="zh">{s.narrationZh}</span></p>
                  <p class="callout tech">
                    <b><span class="en">⚙️ How it works: </span><span class="zh">⚙️ 技术原理：</span></b>
                    <span class="en">{s.techEn}</span><span class="zh">{s.techZh}</span>
                  </p>
                  <p class="callout value">
                    <b><span class="en">💡 Why it matters: </span><span class="zh">💡 业务价值：</span></b>
                    <span class="en">{s.valueEn}</span><span class="zh">{s.valueZh}</span>
                  </p>
                  {s.evidence && (
                    <a class="evidence" href={s.evidence.url} target="_blank" rel="noopener">🔗 {s.evidence.label}</a>
                  )}
                  {s.cases && s.cases.length > 0 && (
                    <div class="cases">{s.cases.map((c) => <span class="case">{c}</span>)}</div>
                  )}
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </main>

    <section class="founder">
      <div class="wrap">
        <div class="founder-card">
          <img src="/panels/founder-jason.png" alt="小J · Jason Jiao" width="320" height="320" loading="lazy" />
          <div class="founder-body">
            <div class="founder-label"><span class="en">Founder</span><span class="zh">创始人</span></div>
            <div class="founder-name">小J · Jason Jiao</div>
            <p class="founder-text">
              <span class="en">An idealist founding the <b>Mycelium</b> collaboration network — using digital public goods to lift the digital wellbeing of ordinary people.</span>
              <span class="zh">理想主义者，致力于创立 <b>Mycelium</b> 协作网络，用数字公共物品提升普通人的数字福祉。</span>
            </p>
            <p class="founder-classical" lang="zh-Hant">理想之士也。志在立菌丝协作之网（Mycelium），以数字公器，济庶民数字之福。</p>
          </div>
        </div>
      </div>
    </section>

    <footer class="site-foot">
      <div class="wrap">
        <p><span class="en">Cos72 Role Tour · narrated by Mycelium's cartoon IPs · comics are illustrative; on-chain evidence is on Sepolia testnet</span><span class="zh">Cos72 角色漫游 · 由 Mycelium 卡通 IP 讲解 · 漫画为示意，链上凭证在 Sepolia 测试网</span></p>
      </div>
    </footer>

    <script is:inline>
      const tabs = document.querySelectorAll(".tab");
      const sections = document.querySelectorAll(".role");
      tabs.forEach((t) => {
        t.addEventListener("click", () => {
          const key = t.getAttribute("data-role");
          tabs.forEach((x) => x.setAttribute("aria-selected", x === t ? "true" : "false"));
          sections.forEach((s) => s.classList.toggle("active", s.getAttribute("data-role") === key));
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      });
      const langBtn = document.getElementById("langBtn");
      langBtn.addEventListener("click", () => {
        const zh = document.body.classList.toggle("lang-zh");
        langBtn.textContent = zh ? "EN" : "中文";
        document.documentElement.lang = zh ? "zh-CN" : "en";
      });
    </script>
  </body>
</html>
